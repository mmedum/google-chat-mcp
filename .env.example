# Copy to .env for local development. Production uses Docker secrets instead.

GCM_BASE_URL=https://chat-mcp.example.com
GCM_DATA_DIR=./data
GCM_LOG_LEVEL=INFO
GCM_RATE_LIMIT_PER_MINUTE=60
GCM_ALLOWED_CLIENT_REDIRECTS=https://claude.ai/api/mcp/auth_callback,https://claude.com/api/mcp/auth_callback

# In production these live in /run/secrets/<name>, not env vars.
GCM_GOOGLE_CLIENT_ID=
GCM_GOOGLE_CLIENT_SECRET=
GCM_FERNET_KEY=
GCM_JWT_SIGNING_KEY=
